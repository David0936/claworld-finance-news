{
  "name": "serenity-analysis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/validate-data.mjs",
    "dev": "next dev",
    "sync:analysissite": "python3 scripts/sync-analysissite.py",
    "realtime": "node scripts/realtime-worker.mjs",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "validate:data": "node scripts/validate-data.mjs",
    "check": "npm run typecheck && npm run validate:data && npm run build",
    "lint": "npm run typecheck"
  },
  "dependencies": {
    "next": "16.2.7",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "6.0.3"
  }
}
